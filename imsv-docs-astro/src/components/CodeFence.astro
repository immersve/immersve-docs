---
import { Code as ExpressiveCode } from "astro-expressive-code/components";
const content = (await Astro.slots.render("default")).trim()
  .replaceAll('&#39;', '\'')
  .replaceAll('&quot;', '"')
  .replaceAll('&lt;', '<')
  .replaceAll('&gt;', '>');
const { title } = Astro.props;
---

<figure class="not-prose">
  <ExpressiveCode
    code={content}
    class={Astro.props.class ?? undefined}
    mark={Astro.props.mark ?? undefined}
    ins={Astro.props.ins ?? undefined}
    del={Astro.props.del ?? undefined}
    frame={Astro.props.frame ?? "auto"}
    lang={Astro.props["data-language"] ?? undefined}
  />
  {title && <figcaption class="mt-2 text-xs text-center italic text-zinc-500 dark:text-zinc-400">{title}</figcaption>}
</figure>
