    "id": "mockCardAcceptorId",
    "terminalId": "mockCardAcceptorTerminalId",
    "city": "mockCardAcceptorCity"
  },
  "securityChallenge": {
    "outcome": "challenge-confirmed",
    "ref": "3ds-ref-123"
  },
  "card": {
    "id": "7624946497485cfcf5a77a81b0ee213b",
    "regionCode": "NZ"
  },
  "cardholder": {
    "id": "d02d361a89095c7629fc"
  },
  "cardProgramId": "9248c576c2da4fdfbfca6dbd0b44d524",
  "feeComposition": [
    {
      "category": "fx",
